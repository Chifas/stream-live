{
  "name": "stream-live",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Plataforma de streaming en directo (tipo Twitch) con Next.js 15, React 19, Tailwind v4 y chat en tiempo real por WebSockets.",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server.ts",
    "build": "next build",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "drizzle-orm": "^0.45.2",
    "hls.js": "^1.5.20",
    "ioredis": "^5.11.1",
    "jose": "^6.2.4",
    "next": "^15.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.11",
    "postcss": "^8.5.0",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
