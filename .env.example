# Secreto para firmar las sesiones JWT. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Base de datos. Por defecto usa un fichero SQLite local (./data/stream.db).
# Para Turso u otra libSQL remota: libsql://tu-db.turso.io con TURSO_AUTH_TOKEN.
DATABASE_URL=file:./data/stream.db

# Puerto y host del servidor.
PORT=3000
HOST=localhost

# Media server MediaMTX (emisión real desde OBS). Valores por defecto locales.
MEDIAMTX_RTMP=rtmp://localhost:1935
MEDIAMTX_HLS_BASE=http://localhost:8888
MEDIAMTX_API=http://localhost:9997

# --- Integraciones opcionales (ver MEJORAS.md) ---
# STRIPE_SECRET_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# SENTRY_DSN=
